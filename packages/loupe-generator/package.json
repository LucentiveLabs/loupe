{
  "name": "@lucentive-labs/loupe-generator",
  "version": "0.1.1",
  "description": "Loupe static-HTML generator (Node-only): generate() bundles a self-contained index.html with JS + CSS inlined and assets copied.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://labs.lucentive.io/libraries/loupe",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LucentiveLabs/loupe.git",
    "directory": "packages/loupe-generator"
  },
  "bugs": "https://github.com/LucentiveLabs/loupe/issues",
  "keywords": [
    "loupe",
    "decision-lock",
    "design-tokens",
    "design-tooling",
    "agent-native",
    "generator",
    "static-html",
    "self-contained",
    "deterministic",
    "esbuild"
  ],
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@lucentive-labs/loupe-core": "workspace:*",
    "@lucentive-labs/loupe-dom": "workspace:*",
    "@lucentive-labs/loupe-schema": "workspace:*",
    "esbuild": "0.28.1"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  }
}
