{
  "name": "@lucentive-labs/loupe-schema",
  "version": "0.2.0",
  "description": "Loupe config schema (Zod) — decision-lock contract + JSON Schema + semantic validator.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://labs.lucentive.io/libraries/loupe",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LucentiveLabs/loupe.git",
    "directory": "packages/loupe-schema"
  },
  "bugs": "https://github.com/LucentiveLabs/loupe/issues",
  "keywords": [
    "loupe",
    "decision-lock",
    "design-tokens",
    "design-tooling",
    "agent-native",
    "zod",
    "json-schema",
    "config-schema",
    "validation"
  ],
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
