{
  "name": "@lucentive-labs/loupe-dom",
  "version": "0.0.0",
  "description": "Loupe browser renderer \u2014 mount(), renderToString(), crop engine, styles.css, applyTheme. Zero framework deps.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://labs.lucentive.io/libraries/loupe",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LucentiveLabs/loupe.git",
    "directory": "packages/loupe-dom"
  },
  "bugs": "https://github.com/LucentiveLabs/loupe/issues",
  "keywords": [
    "loupe",
    "decision-lock",
    "design-tokens",
    "design-tooling",
    "agent-native",
    "dom",
    "renderer",
    "vanilla",
    "ssr",
    "no-framework"
  ],
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./styles.css": "./src/styles.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@lucentive-labs/loupe-core": "workspace:*",
    "@lucentive-labs/loupe-schema": "workspace:*"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./styles.css": "./dist/styles.css"
    }
  }
}
